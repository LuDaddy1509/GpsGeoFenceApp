<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="GpsGeoFence.Pages.PoiDetailPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:GpsGeoFence.ViewModels"
    x:DataType="vm:PoiDetailViewModel"
    Title="{Binding Title}">

    <ContentPage.Resources>
        <Style x:Key="SectionLabel" TargetType="Label">
            <Setter Property="FontSize"      Value="12"/>
            <Setter Property="FontAttributes" Value="Bold"/>
            <Setter Property="TextColor"     Value="#888"/>
            <Setter Property="TextTransform" Value="Uppercase"/>
            <Setter Property="Margin"        Value="0,14,0,4"/>
        </Style>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="CornerRadius"  Value="12"/>
            <Setter Property="HeightRequest" Value="48"/>
            <Setter Property="FontSize"      Value="14"/>
            <Setter Property="Padding"       Value="16,0"/>
        </Style>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- ══ HERO IMAGE ══ -->
            <Grid HeightRequest="220">
                <!-- Ảnh POI -->
                <Image
                    IsVisible="{Binding HasImage}"
                    Source="{Binding Poi.ImageUrl}"
                    Aspect="AspectFill"/>

                <!-- Placeholder nếu không có ảnh -->
                <ContentView
                    IsVisible="{Binding HasImage, Converter={StaticResource InverseBoolConverter}}"
                    BackgroundColor="#E3F2FD">
                    <Label
                        Text="📍"
                        FontSize="72"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"/>
                </ContentView>

                <!-- Gradient overlay phía dưới ảnh -->
                <BoxView VerticalOptions="End" HeightRequest="80">
                    <BoxView.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="Transparent" Offset="0"/>
                            <GradientStop Color="#CC000000" Offset="1"/>
                        </LinearGradientBrush>
                    </BoxView.Background>
                </BoxView>

                <!-- Khoảng cách badge -->
                <Border
                    HorizontalOptions="End"
                    VerticalOptions="End"
                    Margin="12"
                    BackgroundColor="#2196F3"
                    StrokeShape="RoundRectangle 20"
                    Stroke="Transparent"
                    Padding="10,5">
                    <Label
                        Text="{Binding DistanceText, StringFormat='📍 {0}'}"
                        FontSize="13" FontAttributes="Bold"
                        TextColor="White"/>
                </Border>
            </Grid>

            <!-- ══ CONTENT AREA ══ -->
            <VerticalStackLayout Padding="16,12" Spacing="0">

                <!-- Tên POI -->
                <Label
                    Text="{Binding Poi.Name}"
                    FontSize="22" FontAttributes="Bold"
                    TextColor="{AppThemeBinding Light=#1A1A1A, Dark=White}"
                    LineBreakMode="WordWrap"/>

                <!-- Priority badge -->
                <HorizontalStackLayout Margin="0,4,0,0" Spacing="6">
                    <Border
                        BackgroundColor="#FFF3E0"
                        StrokeShape="RoundRectangle 10"
                        Stroke="Transparent"
                        Padding="8,3">
                        <Label
                            Text="{Binding Poi.Priority, StringFormat='Ưu tiên #{0}'}"
                            FontSize="11"
                            TextColor="#E65100"/>
                    </Border>
                    <Border
                        BackgroundColor="#E8F5E9"
                        StrokeShape="RoundRectangle 10"
                        Stroke="Transparent"
                        Padding="8,3">
                        <Label
                            Text="{Binding Poi.RadiusMeters, StringFormat='Bán kính {0}m'}"
                            FontSize="11"
                            TextColor="#2E7D32"/>
                    </Border>
                </HorizontalStackLayout>

                <!-- ── NÚT PHÁT THUYẾT MINH ── -->
                <Border
                    Margin="0,16,0,0"
                    BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2C2C2C}"
                    StrokeShape="RoundRectangle 16"
                    Stroke="Transparent"
                    Padding="16">
                    <VerticalStackLayout Spacing="12">

                        <!-- Language picker -->
                        <Grid ColumnDefinitions="Auto,*">
                            <Label
                                Grid.Column="0"
                                Text="Ngôn ngữ:"
                                FontSize="14"
                                VerticalOptions="Center"
                                TextColor="{AppThemeBinding Light=#555, Dark=#AAA}"/>
                            <Picker
                                Grid.Column="1"
                                Margin="8,0,0,0"
                                ItemsSource="{Binding AvailableLanguages}"
                                SelectedItem="{Binding SelectedLanguage}"
                                FontSize="14"
                                HorizontalOptions="Start"/>
                        </Grid>

                        <!-- Play button -->
                        <Button
                            Text="{Binding PlayButtonText}"
                            BackgroundColor="{Binding IsPlayingAudio,
                                Converter={StaticResource BoolToColorConverter},
                                ConverterParameter='#F44336|#4CAF50'}"
                            TextColor="White"
                            FontSize="16" FontAttributes="Bold"
                            HeightRequest="52"
                            CornerRadius="14"
                            Command="{Binding TogglePlayCommand}">
                            <Button.Shadow>
                                <Shadow Brush="#444CAF50" Offset="0,3" Radius="8"/>
                            </Button.Shadow>
                        </Button>

                        <!-- Progress bar (hiện khi đang phát) -->
                        <VerticalStackLayout IsVisible="{Binding IsPlayingAudio}" Spacing="4">
                            <ProgressBar
                                Progress="{Binding PlayProgress}"
                                ProgressColor="#4CAF50"
                                HeightRequest="6"/>
                            <Label
                                Text="{Binding ProgressText}"
                                FontSize="11"
                                TextColor="#888"
                                HorizontalOptions="End"/>
                        </VerticalStackLayout>

                        <!-- Reset cooldown -->
                        <Button
                            Text="↺ Reset cooldown"
                            BackgroundColor="Transparent"
                            TextColor="#2196F3"
                            FontSize="13"
                            HeightRequest="36"
                            CornerRadius="8"
                            Command="{Binding ResetCooldownCommand}"/>
                    </VerticalStackLayout>
                </Border>

                <!-- ── MÔ TẢ ── -->
                <Label Style="{StaticResource SectionLabel}" Text="Giới thiệu"/>
                <Label
                    Text="{Binding Poi.Description}"
                    FontSize="15"
                    LineHeight="1.5"
                    TextColor="{AppThemeBinding Light=#333, Dark=#CCC}"
                    LineBreakMode="WordWrap"/>

                <!-- ── TỌA ĐỘ ── -->
                <Label Style="{StaticResource SectionLabel}" Text="Vị trí"/>
                <Border
                    BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2C2C2C}"
                    StrokeShape="RoundRectangle 12"
                    Stroke="Transparent"
                    Padding="14,10">
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto">
                        <Label Grid.Row="0" Grid.Column="0" Text="Vĩ độ"  FontSize="11" TextColor="#888"/>
                        <Label Grid.Row="0" Grid.Column="1" Text="Kinh độ" FontSize="11" TextColor="#888"/>
                        <Label
                            Grid.Row="1" Grid.Column="0"
                            Text="{Binding Poi.Latitude, StringFormat='{0:F6}'}"
                            FontSize="14" FontAttributes="Bold"
                            TextColor="{AppThemeBinding Light=#1A1A1A, Dark=White}"/>
                        <Label
                            Grid.Row="1" Grid.Column="1"
                            Text="{Binding Poi.Longitude, StringFormat='{0:F6}'}"
                            FontSize="14" FontAttributes="Bold"
                            TextColor="{AppThemeBinding Light=#1A1A1A, Dark=White}"/>
                    </Grid>
                </Border>

                <!-- ── ACTIONS ── -->
                <Label Style="{StaticResource SectionLabel}" Text="Hành động"/>
                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                    <!-- Mở bản đồ -->
                    <Button
                        Grid.Column="0"
                        Style="{StaticResource ActionBtn}"
                        Text="🗺 Chỉ đường"
                        BackgroundColor="#E3F2FD"
                        TextColor="#1565C0"
                        Command="{Binding OpenMapCommand}"/>

                    <!-- Chia sẻ -->
                    <Button
                        Grid.Column="1"
                        Style="{StaticResource ActionBtn}"
                        Text="↑ Chia sẻ"
                        BackgroundColor="#E8F5E9"
                        TextColor="#2E7D32"
                        Command="{Binding SharePoiCommand}"/>
                </Grid>

                <!-- Mở link bản đồ (nếu có) -->
                <Button
                    Margin="0,10,0,0"
                    IsVisible="{Binding HasMapLink}"
                    Style="{StaticResource ActionBtn}"
                    Text="🔗 Xem bản đồ chi tiết"
                    BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2C2C2C}"
                    TextColor="{AppThemeBinding Light=#333, Dark=#DDD}"
                    HorizontalOptions="Fill"
                    Command="{Binding OpenMapLinkCommand}"/>

                <BoxView HeightRequest="32" Color="Transparent"/>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

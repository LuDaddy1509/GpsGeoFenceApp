<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MauiApp1.Pages.MapPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
    Title="Bản đồ &amp; POI">
    <!-- ✅ &amp; thay vì & -->

    <!-- Dùng Grid để tránh cảnh báo FillAndExpand -->
    <Grid RowDefinitions="Auto,*" ColumnDefinitions="*">
        <HorizontalStackLayout Grid.Row="0" Padding="10" Spacing="12">
            <Button x:Name="BtnStart" Text="Bắt đầu" />
            <Button x:Name="BtnStop"  Text="Dừng" />
        </HorizontalStackLayout>
        <maps:Map x:Name="MyMap"
                  Grid.Row="1"
                  MapType="Street"
                  IsShowingUser="True"/>
    </Grid>
</ContentPage>
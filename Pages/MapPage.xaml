<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="GpsGeoFence.Pages.MapPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
    xmlns:vm="clr-namespace:GpsGeoFence.ViewModels"
    x:DataType="vm:MapViewModel"
    Shell.NavBarIsVisible="False">

    <ContentPage.Resources>
        <Color x:Key="PrimaryColor">#2196F3</Color>
        <Color x:Key="SuccessColor">#4CAF50</Color>
        <Color x:Key="DangerColor">#F44336</Color>
    </ContentPage.Resources>

    <Grid>
        <!-- ══ LAYER 1: BẢN ĐỒ ══
             ✅ FIX: Bỏ VisibleRegion binding — set từ code-behind
             ✅ FIX: Bỏ ItemsSource binding trên Map (dùng Pins thay thế)
             ✅ FIX: Event handlers đặt trong code-behind, không binding XAML -->
        <maps:Map
            x:Name="MainMap"
            MapType="Street"
            IsShowingUser="True"
            IsScrollEnabled="True"
            IsZoomEnabled="True"/>

        <!-- ══ LAYER 2: TOP STATUS BAR ══ -->
        <Border
            Margin="12,48,12,0"
            VerticalOptions="Start"
            BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
            StrokeShape="RoundRectangle 16"
            Stroke="Transparent"
            Padding="14,10">
            <Border.Shadow>
                <Shadow Brush="#44000000" Offset="0,2" Radius="8"/>
            </Border.Shadow>
            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                <Label
                    Grid.Column="0" Grid.Row="0"
                    Text="GPS GeoFence"
                    FontSize="16" FontAttributes="Bold"
                    TextColor="{AppThemeBinding Light=#1A1A1A, Dark=White}"/>
                <HorizontalStackLayout Grid.Column="1" Grid.Row="0" Spacing="4">
                    <Ellipse WidthRequest="8" HeightRequest="8" VerticalOptions="Center">
                        <Ellipse.Fill>
                            <SolidColorBrush Color="#4CAF50"/>
                        </Ellipse.Fill>
                    </Ellipse>
                    <Label
                        Text="{Binding IsTracking}"
                        FontSize="12"
                        TextColor="{AppThemeBinding Light=#555, Dark=#AAA}"
                        VerticalOptions="Center"/>
                </HorizontalStackLayout>
                <Label
                    Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="2"
                    Text="{Binding StatusMessage}"
                    FontSize="12"
                    TextColor="{AppThemeBinding Light=#666, Dark=#AAA}"
                    LineBreakMode="TailTruncation"/>
            </Grid>
        </Border>

        <!-- ══ LAYER 3: POI NEAR BANNER ══ -->
        <Border
            Margin="12,0,12,100"
            VerticalOptions="End"
            IsVisible="{Binding HasNearestPoi}"
            BackgroundColor="#E3F2FD"
            StrokeShape="RoundRectangle 14"
            Stroke="#2196F3"
            StrokeThickness="1"
            Padding="14,10">
            <Grid ColumnDefinitions="*,Auto">
                <VerticalStackLayout Grid.Column="0" Spacing="2">
                    <Label Text="Gần bạn" FontSize="11" TextColor="#1565C0"/>
                    <Label
                        Text="{Binding NearestPoiName}"
                        FontSize="15" FontAttributes="Bold"
                        TextColor="#0D47A1"
                        LineBreakMode="TailTruncation"/>
                    <Label
                        Text="{Binding NearestPoiDistance, StringFormat='{0:F0} mét'}"
                        FontSize="12" TextColor="#1976D2"/>
                </VerticalStackLayout>
                <Button
                    Grid.Column="1"
                    Text="Chi tiết"
                    FontSize="13"
                    BackgroundColor="#2196F3"
                    TextColor="White"
                    CornerRadius="10"
                    Padding="12,6"
                    Command="{Binding SelectPoiCommand}"
                    CommandParameter="{Binding CurrentNearestPoi}"/>
            </Grid>
        </Border>

        <!-- ══ LAYER 4: AUDIO PLAYING BANNER ══ -->
        <Border
            Margin="12,0,12,160"
            VerticalOptions="End"
            IsVisible="{Binding IsPlayingAudio}"
            BackgroundColor="#E8F5E9"
            StrokeShape="RoundRectangle 14"
            Stroke="#4CAF50"
            StrokeThickness="1"
            Padding="14,10">
            <HorizontalStackLayout Spacing="10">
                <Label Text="🔊" FontSize="20" VerticalOptions="Center"/>
                <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                    <Label Text="Đang phát thuyết minh"
                           FontSize="13" FontAttributes="Bold"
                           TextColor="#2E7D32"/>
                    <Label Text="{Binding PlayingPoiName}"
                           FontSize="12" TextColor="#388E3C"/>
                </VerticalStackLayout>
            </HorizontalStackLayout>
        </Border>

        <!-- ══ LAYER 5: ACTION BUTTONS ══ -->
        <VerticalStackLayout
            Margin="0,0,16,32"
            HorizontalOptions="End"
            VerticalOptions="End"
            Spacing="12">

            <!-- Nút QR -->
            <Button
                HeightRequest="56" WidthRequest="56"
                CornerRadius="28" Padding="0" FontSize="22"
                Text="⊡"
                BackgroundColor="White"
                TextColor="#333"
                Command="{Binding ScanQrCommand}"/>

            <!-- Nút My Location -->
            <Button
                HeightRequest="56" WidthRequest="56"
                CornerRadius="28" Padding="0" FontSize="22"
                Text="◎"
                BackgroundColor="White"
                TextColor="#2196F3"
                Command="{Binding CenterMapCommand}"/>

            <!-- Nút Start/Stop GPS -->
            <Button
                HeightRequest="64" WidthRequest="64"
                CornerRadius="32" Padding="0" FontSize="24"
                Text="{Binding IsTracking, StringFormat='{0}'}"
                BackgroundColor="#4CAF50"
                TextColor="White"
                Command="{Binding ToggleTrackingCommand}">
                <Button.Shadow>
                    <Shadow Brush="#66000000" Offset="0,3" Radius="10"/>
                </Button.Shadow>
            </Button>
        </VerticalStackLayout>

        <!-- ══ LAYER 6: LOADING OVERLAY ══ -->
        <Grid IsVisible="{Binding IsBusy}" BackgroundColor="#44000000">
            <Border
                HorizontalOptions="Center"
                VerticalOptions="Center"
                BackgroundColor="{AppThemeBinding Light=White, Dark=#2C2C2C}"
                StrokeShape="RoundRectangle 16"
                Padding="24,20">
                <VerticalStackLayout Spacing="12" HorizontalOptions="Center">
                    <ActivityIndicator IsRunning="True" Color="#2196F3" HeightRequest="40"/>
                    <Label
                        Text="{Binding BusyMessage}"
                        FontSize="14"
                        TextColor="{AppThemeBinding Light=#333, Dark=#DDD}"
                        HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- ══ LAYER 7: ERROR BANNER ══ -->
        <Border
            x:Name="ErrorBanner"
            Margin="12,0,12,16"
            VerticalOptions="End"
            IsVisible="{Binding HasError}"
            BackgroundColor="#FFEBEE"
            StrokeShape="RoundRectangle 12"
            Stroke="#F44336"
            StrokeThickness="1"
            Padding="14,10">
            <Grid ColumnDefinitions="*,Auto">
                <Label
                    Grid.Column="0"
                    Text="{Binding ErrorMessage}"
                    FontSize="13"
                    TextColor="#C62828"/>
                <!-- ✅ FIX: dùng x:Name + Clicked trong code-behind thay vì binding event -->
                <Button
                    Grid.Column="1"
                    x:Name="DismissErrorBtn"
                    Text="✕" FontSize="14"
                    BackgroundColor="Transparent"
                    TextColor="#C62828"
                    Padding="8,0"/>
            </Grid>
        </Border>
    </Grid>
</ContentPage>

<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="GpsGeoFence.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:GpsGeoFence.Pages"
    Shell.FlyoutBehavior="Disabled">

    <Shell.Resources>
        <Style TargetType="TabBar">
            <Setter Property="Shell.TabBarBackgroundColor"
                    Value="{AppThemeBinding Light=White, Dark=#1E1E1E}"/>
            <Setter Property="Shell.TabBarForegroundColor"    Value="#2196F3"/>
            <Setter Property="Shell.TabBarTitleColor"         Value="#2196F3"/>
            <Setter Property="Shell.TabBarUnselectedColor"    Value="#9E9E9E"/>
        </Style>
    </Shell.Resources>

    <TabBar>
        <Tab Title="Bản đồ" Icon="tab_map.png">
            <ShellContent
                Route="map"
                ContentTemplate="{DataTemplate pages:MapPage}"/>
        </Tab>
        <Tab Title="Cài đặt" Icon="tab_settings.png">
            <ShellContent
                Route="settings"
                ContentTemplate="{DataTemplate pages:SettingsPage}"/>
        </Tab>
    </TabBar>

</Shell>
